unicipio": "Pilar", "uf": "AL", "total": 8, "populacao": 35702, "taxa": 22.41, "piso_populacao": 30000}, {"codigo_ibge": "4205506", "municipio": "Fraiburgo", "uf": "SC", "total": 8, "populacao": 35844, "taxa": 22.32, "piso_populacao": 30000}, {"codigo_ibge": "2918100", "municipio": "Jeremoabo", "uf": "BA", "total": 9, "populacao": 40383, "taxa": 22.29, "piso_populacao": 30000}, {"codigo_ibge": "2301901", "municipio": "Barbalha", "uf": "CE", "total": 15, "populacao": 67313, "taxa": 22.28, "piso_populacao": 30000}, {"codigo_ibge": "4308201", "municipio": "Flores da Cunha", "uf": "RS", "total": 7, "populacao": 31558, "taxa": 22.18, "piso_populacao": 30000}, {"codigo_ibge": "2203701", "municipio": "Esperantina", "uf": "PI", "total": 9, "populacao": 40788, "taxa": 22.07, "piso_populacao": 30000}, {"codigo_ibge": "4101408", "municipio": "Apucarana", "uf": "PR", "total": 30, "populacao": 136386, "taxa": 22.0, "piso_populacao": 30000}, {"codigo_ibge": "2601201", "municipio": "Arcoverde", "uf": "PE", "total": 17, "populacao": 77468, "taxa": 21.94, "piso_populacao": 30000}, {"codigo_ibge": "4209409", "municipio": "Laguna", "uf": "SC", "total": 10, "populacao": 45599, "taxa": 21.93, "piso_populacao": 30000}, {"codigo_ibge": "2601102", "municipio": "Araripina", "uf": "PE", "total": 19, "populacao": 86873, "taxa": 21.87, "piso_populacao": 30000}, {"codigo_ibge": "2506301", "municipio": "Guarabira", "uf": "PB", "total": 13, "populacao": 59538, "taxa": 21.83, "piso_populacao": 30000}, {"codigo_ibge": "4124103", "municipio": "Santo Antônio da Platina", "uf": "PR", "total": 10, "populacao": 46178, "taxa": 21.66, "piso_populacao": 30000}, {"codigo_ibge": "2615300", "municipio": "Timbaúba", "uf": "PE", "total": 11, "populacao": 50860, "taxa": 21.63, "piso_populacao": 30000}, {"codigo_ibge": "5217401", "municipio": "Pires do Rio", "uf": "GO", "total": 7, "populacao": 32429, "taxa": 21.59, "piso_populacao": 30000}, {"codigo_ibge": "2609501", "municipio": "Nazaré da Mata", "uf": "PE", "total": 7, "populacao": 32499, "taxa": 21.54, "piso_populacao": 30000}, {"codigo_ibge": "3509700", "municipio": "Campos do Jordão", "uf": "SP", "total": 11, "populacao": 51087, "taxa": 21.53, "piso_populacao": 30000}, {"codigo_ibge": "3533908", "municipio": "Olímpia", "uf": "SP", "total": 12, "populacao": 55882, "taxa": 21.47, "piso_populacao": 30000}, {"codigo_ibge": "5106505", "municipio": "Poconé", "uf": "MT", "total": 7, "populacao": 32665, "taxa": 21.43, "piso_populacao": 30000}], "fonte": "SIM/DataSUS — microdado da declaração de óbito: causa básica (CAUSABAS) e as linhas do atestado (LINHAA–LINHAD, LINHAII), em CID-10.", "notas": {"piso_e_teto": "A menção CONTÉM a causa básica: toda morte por álcool também é uma morte que cita álcool. Somar as duas contaria a mesma pessoa duas vezes — por isso a tela mostra o EXCEDENTE (cita, mas a causa básica é outra), não a soma.", "silencio": "O álcool quase não aparece na certidão de quem morre de morte violenta. Existem os códigos Y90 e Y91 (teor alcoólico no sangue) e eles são usados numa fração ínfima dos homicídios. Isso NÃO significa que não havia álcool na briga ou no volante — significa que a declaração de óbito registra o trauma, não a bebida. O número mede o registro.", "x65": "O X65 (autointoxicação voluntária por álcool) é morte por álcool E suicídio. Ele é contado nos dois lugares, de propósito: sairia da tela do suicídio se virasse 'álcool', e sumiria daqui se ficasse só como suicídio. As duas contagens estão certas; o que seria errado é somá-las.", "subnotificacao": "Cirrose alcoólica costuma ser declarada apenas como 'cirrose' (K74), sem o álcool. O piso é, portanto, o piso do piso — a literatura estima a mortalidade real atribuível ao álcool em várias vezes qualquer contagem por CID."}}